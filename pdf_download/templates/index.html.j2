<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Journals Inbox · {{ fetch_date }}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", "PingFang TC", sans-serif;
         background: #fafaf7; color: #1a1a1a; margin: 0; padding: 0; line-height: 1.6; }
  .container { max-width: 880px; margin: 0 auto; padding: 24px 20px; }
  header { background: white; border: 1px solid #e5e5dc; border-radius: 12px;
           padding: 24px 28px; margin-bottom: 20px; }
  header h1 { margin: 0 0 8px; }
  header .meta { color: #666; }
  table { width: 100%; background: white; border: 1px solid #e5e5dc; border-radius: 12px;
          border-collapse: separate; border-spacing: 0; overflow: hidden; }
  th, td { padding: 12px 16px; text-align: left; border-bottom: 1px solid #e5e5dc; }
  th { background: #f5f5ef; font-weight: 600; }
  tr:last-child td { border-bottom: none; }
  td a { color: #0066cc; text-decoration: none; }
  td a:hover { text-decoration: underline; }
  .oa-tag { color: #1a8a3a; font-weight: 600; }
  .failures { background: #fff8e8; border: 1px solid #f0d878; border-radius: 8px;
              padding: 14px 18px; margin-top: 20px; }
  .failures h3 { margin-top: 0; }
</style>
</head>
<body>
<div class="container">
  <header>
    <h1>Journals Inbox · {{ fetch_date }}</h1>
    <div class="meta">
      抓取於 {{ fetched_at }} · <strong>{{ issues | length }}</strong> 個期刊 ·
      <strong>{{ total_articles }}</strong> 篇文章 ·
      <strong class="oa-tag">{{ total_oa }} OA</strong>
    </div>
  </header>

  <table>
    <thead>
      <tr>
        <th>期刊</th><th>期數</th><th>出刊日</th>
        <th>篇數</th><th>OA</th><th>檔案</th>
      </tr>
    </thead>
    <tbody>
      {% for issue in issues %}
      <tr>
        <td><strong>{{ issue.journal_abbrev }}</strong></td>
        <td>{% if issue.volume or issue.issue %}{{ issue.volume or '—' }}/{{ issue.issue or '—' }}{% else %}AOP{% endif %}</td>
        <td>{{ issue.publication_date }}</td>
        <td>{{ issue.articles | length }}</td>
        <td><span class="oa-tag">{{ issue.oa_count }}</span></td>
        <td><a href="{{ issue.filename_stem }}.html">開啟 →</a></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  {% if failed %}
  <div class="failures">
    <h3>⚠️ 失敗紀錄</h3>
    <ul>
      {% for f in failed %}
      <li><strong>{{ f.journal }}</strong>: {{ f.reason }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}
</div>
</body>
</html>
